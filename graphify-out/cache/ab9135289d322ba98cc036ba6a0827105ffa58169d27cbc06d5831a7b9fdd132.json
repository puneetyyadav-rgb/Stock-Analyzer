onst downMinY = alphaPct + downBeta * downMinX;\r\n\r\n                        return (\r\n                          <>\r\n                            <Scatter\r\n                              name=\"Up Slope (\u03b2+)\"\r\n                              data={[{ nifty: 0, stock: alphaPct }, { nifty: upMaxX, stock: upMaxY }]}\r\n                              line={{ stroke: \"#10b981\", strokeWidth: 2.5 }}\r\n                              shape={() => null}\r\n                              legendType=\"none\"\r\n                            />\r\n                            <Scatter\r\n                              name=\"Down Slope (\u03b2-)\"\r\n                              data={[{ nifty: downMinX, stock: downMinY }, { nifty: 0, stock: alphaPct }]}\r\n                              line={{ stroke: \"#ef4444\", strokeWidth: 2.5 }}\r\n                              shape={() => null}\r\n                              legendType=\"none\"\r\n                            />\r\n                            <ReferenceLine\r\n                              segment={[{ x: 0, y: alphaPct }, { x: upMaxX, y: upMaxY }]}\r\n                              stroke=\"#10b981\"\r\n                              strokeWidth={2.5}\r\n                            />\r\n                            <ReferenceLine\r\n                              segment={[{ x: downMinX, y: downMinY }, { x: 0, y: alphaPct }]}\r\n                              stroke=\"#ef4444\"\r\n                              strokeWidth={2.5}\r\n                            />\r\n                          </>\r\n                        );\r\n                      })", "source_file": "E:\\Website\\Stock Analysis\\stock ticker v2\\frontend\\src\\components\\StockMacroCouplingWidget.jsx", "source_location": "L319"}, {"caller_nid": "stockmacrocouplingwidget_stockmacrocouplingwidget", "callee": "map", "source_file": "E:\\Website\\Stock Analysis\\stock ticker v2\\frontend\\src\\components\\StockMacroCouplingWidget.jsx", "source_location